# Core
ENV=dev
DATABASE_URL=postgresql+psycopg://autohaggle:autohaggle@localhost:5432/autohaggle
REDIS_URL=redis://localhost:6379/0
COMMUNICATION_SERVICE_URL=http://localhost:8010
EMAIL_PROVIDER=sendgrid
WEBHOOK_SHARED_SECRET=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Gmail SMTP (optional)
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_FROM_EMAIL=

# Market Data (Aggregator API, API-first path)
MARKETCHECK_API_KEY=
MARKETCHECK_BASE_URL=https://api.marketcheck.com/v2/search/car/active

# Direct Dealer Scrape (optional fallback, keep disabled for API-only mode)
DEALER_DIRECT_SCRAPE_ENABLED=false

# LLM
OPENAI_API_KEY=

# Toyota GraphQL (for WAF-protected inventory endpoint)
TOYOTA_GRAPHQL_ENDPOINT=https://api.search-inventory.toyota.com/graphql
TOYOTA_GRAPHQL_ORIGIN=https://www.toyota.com
TOYOTA_GRAPHQL_REFERER=https://www.toyota.com/
TOYOTA_GRAPHQL_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36
TOYOTA_X_API_KEY=
TOYOTA_X_AWS_WAF_TOKEN=
TOYOTA_GRAPHQL_COOKIE=
TOYOTA_GRAPHQL_EXTRA_HEADERS_JSON=

# Scheduled Fallback Ingest Worker
FALLBACK_INGEST_INTERVAL_MINUTES=360
FALLBACK_INGEST_RUN_ONCE=false
FALLBACK_INGEST_USER_ZIP=18706
FALLBACK_INGEST_RADIUS_MILES=100
FALLBACK_INGEST_BUDGET_OTD=45000
FALLBACK_INGEST_TARGETS_JSON=[{"make":"Toyota","model":"RAV4","year":2025},{"make":"Honda","model":"Civic","year":2025}]
FALLBACK_INGEST_DEALER_SITES_JSON=[]
